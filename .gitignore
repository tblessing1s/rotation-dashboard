# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Runtime state & caches (DATA_DIR; on Fly this lives on the /data volume)
backend/state.json
backend/schwab_token.json
backend/earnings_cache.json
backend/cache/
data/cache/
# Demo-mode store (synthetic data, never committed)
backend/state.demo.json
backend/cache_demo/
backend/mode.json
# Durability backups, pre-migration snapshots, restore-aside + write-temp files
# (DATA_DIR/backups; on Fly the /data volume — never commit real state)
backend/backups/
data/backups/
backend/state.json.pre-restore.*
backend/state.demo.json.pre-restore.*
backend/state.json.tmp.*
backend/state.demo.json.tmp.*
# Auto-generated cookie-signing key (persisted so sessions survive restarts)
backend/.session_secret
.session_secret

# Node/Vite
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Local env/files
.env
.env.*
.DS_Store
